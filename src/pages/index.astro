---
import Layout from '../layouts/Layout.astro';
import data from '../../data.json';

const mcpRegistry = data.mcpRegistry;
const learningResources = data.learningResources;

// Map category IDs to user-friendly titles
const categoryMap = {
  "llm-fundamentals": "LLM Fundamentals",
  "agent-orchestration": "Agent Orchestration",
  "custom-mcp": "Custom MCP Dev"
};
---

<Layout 
  title="MCP Hub | The Ultimate Model Context Protocol Registry" 
  description="Discover, search, and dynamically generate mcp_config.json configurations for the best Model Context Protocol (MCP) servers and learning resources."
  canonicalUrl="https://mcptools.dev"
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container text-center">
      <div class="badge">Model Context Protocol Registry</div>
      <h1 class="hero-title">Connect LLMs to the <span class="text-gradient">Real World</span></h1>
      <p class="hero-subtitle">
        Explore production-ready MCP servers, generate configuration files, and access the best learning resources to build intelligent agent workflows.
      </p>

      <!-- Main Navigation Tabs -->
      <div class="page-tabs" role="tablist" aria-label="Registry Sections">
        <button class="page-tab active" data-tab="servers" role="tab" aria-selected="true" aria-controls="view-servers" id="tab-servers"><span role="img" aria-hidden="true">⚡</span> MCP Servers</button>
        <button class="page-tab" data-tab="learning" role="tab" aria-selected="false" aria-controls="view-learning" id="tab-learning"><span role="img" aria-hidden="true">📚</span> Learning & Resources</button>
        <button class="page-tab" data-tab="validator" role="tab" aria-selected="false" aria-controls="view-validator" id="tab-validator"><span role="img" aria-hidden="true">🛠️</span> Config Validator</button>
      </div>

      <!-- Search Container -->
      <div class="search-container">
        <div class="search-box">
          <span class="search-icon" role="img" aria-hidden="true">🔍</span>
          <label for="search-input" class="sr-only">Search servers or resources</label>
          <input type="text" id="search-input" placeholder="Search servers (e.g. Postgres, Slack, Kite...)" autocomplete="off">
        </div>
      </div>
      <!-- Screen reader search results announcements -->
      <div id="search-results-announcer" class="sr-only" aria-live="polite"></div>
    </div>
  </section>

  <!-- Servers View (Tab 1) -->
  <div id="view-servers" class="tab-view active" role="tabpanel" aria-labelledby="tab-servers" tabindex="0">
    <!-- Servers Explorer Section -->
    <section id="servers-explorer" class="explorer-section container">
      <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
        <h2 class="section-title">Explore Servers</h2>
        <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
          <div class="category-filters" id="category-filters">
            <button class="filter-btn active" data-category="all">All Tools</button>
            <button class="filter-btn" data-category="databases">Databases</button>
            <button class="filter-btn" data-category="apis">APIs & Chat</button>
            <button class="filter-btn" data-category="search">Search & Web</button>
            <button class="filter-btn" data-category="utilities">Utilities</button>
          </div>
          <div class="layout-toggles" id="layout-toggles" style="display: flex; background: rgba(20, 27, 41, 0.75); border: 1px solid var(--card-border); padding: 4px; border-radius: 8px; gap: 4px;">
            <button class="layout-btn active" data-layout="grid" title="Grid View" style="background: none; border: none; color: var(--text-secondary); padding: 6px 12px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.85rem; font-family: var(--font-title); transition: var(--transition-smooth);">
              🎴 Grid
            </button>
            <button class="layout-btn" data-layout="list" title="List View" style="background: none; border: none; color: var(--text-secondary); padding: 6px 12px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; gap: 6px; font-weight: 600; font-size: 0.85rem; font-family: var(--font-title); transition: var(--transition-smooth);">
              ☰ List
            </button>
          </div>
        </div>
      </div>

      <!-- Server Grid (Pre-rendered for SEO) -->
      <div class="server-grid" id="server-grid">
        {mcpRegistry.map((server, idx) => (
          <div 
            class="server-card glass-panel" 
            data-server-id={server.id} 
            data-category={server.category}
            style={idx >= 12 ? "display: none;" : ""}
          >
            <div class="card-top">
              <div class="card-title-wrap">
                <span class="card-icon" role="img" aria-hidden="true">{server.icon}</span>
                <div>
                  <h3 class="card-name">{server.name}</h3>
                  <span class="card-badge">{server.category}</span>
                </div>
              </div>
            </div>
            <p class="card-desc">{server.description}</p>
            
            <div class="card-actions">
              <div class="card-install">
                <span class="install-cmd" id={`cmd-${server.id}`}>{server.command}</span>
                <button class="btn-copy" onclick={`copyText('cmd-${server.id}', 'Command copied!')`} title="Copy install command" aria-label="Copy install command">
                  <span aria-hidden="true">📋</span>
                </button>
              </div>
              <button class="btn-card-action" onclick={`copyServerConfig('${server.id}')`} title="Copy default mcp_config.json block">
                <span role="img" aria-hidden="true">⚙️</span> Copy JSON
              </button>
            </div>
            
            <div class="card-footer">
              <span class="card-author">By {server.author} &bull; <a href={`/servers/${server.id}`} class="details-link" style="color: var(--accent-blue); text-decoration: none; font-weight: 500;">Details &rarr;</a></span>
              <span class="card-stars"><span role="img" aria-label="stars">⭐️</span> {server.stars}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Servers Pagination Container -->
      <div id="servers-pagination" class="pagination-container" style="display: flex; justify-content: center; align-items: center; gap: 8px; margin-top: 40px; flex-wrap: wrap;">
      </div>
    </section>

    <!-- Dynamic Configuration Generator Section -->
    <section id="config-generator" class="generator-section">
      <div class="container">
        <div class="section-title-wrap text-center">
          <div class="badge">Config Builder</div>
          <h2>Interactive <span class="text-gradient">mcp_config.json</span> Builder</h2>
          <p class="section-subtitle">Select the tools you want to use, customize their configuration arguments, and copy the unified configuration file directly into your agent setup.</p>
        </div>

        <div class="generator-layout">
          <!-- Configuration Controls (Left) -->
          <div class="generator-controls glass-panel">
            <h3 class="panel-title">1. Select & Configure Servers</h3>
            <div class="controls-list" id="controls-list">
              <!-- Dynamically populated checkboxes and inputs -->
            </div>
          </div>

          <!-- JSON Output Preview (Right) -->
          <div class="generator-output glass-panel">
            <div class="output-header">
              <h3 class="panel-title">2. Live config file</h3>
              <button class="btn btn-secondary btn-sm copy-config-btn" id="copy-config-btn">
                <span class="btn-icon">📋</span> Copy Configuration
              </button>
            </div>
            <div class="code-container">
              <pre><code id="json-preview">// Configuration will generate here...</code></pre>
            </div>
            <div class="config-instructions">
              <h4>💡 How to Use:</h4>
              <p>Save this code as <code>mcp_config.json</code> in your local app configuration directory (e.g., <code>~/Library/Application Support/Antigravity/mcp_config.json</code> or your Claude Desktop config folder).</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start Guide -->
    <section id="quickstart" class="quickstart-section container">
      <div class="glass-panel quickstart-panel">
        <div class="quickstart-grid">
          <div class="quickstart-content">
            <div class="badge">Developer Guide</div>
            <h2>Build Your Own <span class="text-gradient">MCP Server</span></h2>
            <p>Writing custom MCP servers is simple. Create integrations in Node.js or Python to give your AI workspace access to proprietary systems and APIs.</p>
            
            <div class="step-list">
              <div class="step-item">
                <div class="step-num">1</div>
                <div>
                  <strong>Install the SDK:</strong> Start by installing the model-context-protocol client/server library.
                </div>
              </div>
              <div class="step-item">
                <div class="step-num">2</div>
                <div>
                  <strong>Define Tools:</strong> Register tool functions, descriptions, and parameter schemas.
                </div>
              </div>
              <div class="step-item">
                <div class="step-num">3</div>
                <div>
                  <strong>Expose Endpoints:</strong> Read/write inputs over stdio or HTTP endpoints.
                </div>
              </div>
            </div>
          </div>

          <div class="quickstart-code">
            <div class="code-header">
              <span class="code-title">server.js (Node.js SDK)</span>
              <button class="btn-copy-code" data-copy-target="node-sdk-code">Copy</button>
            </div>
            <div class="code-container">
              <pre><code id="node-sdk-code">{`import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";

// Initialize server
const server = new Server({
  name: "custom-mcp-server",
  version: "1.0.0"
}, {
  capabilities: { tools: {} }
});

// Define a tool
server.setRequestHandler(ListToolsRequestSchema, async () => ({
  tools: [{
    name: "calculate_metric",
    description: "Computes custom business analytics",
    inputSchema: {
      type: "object",
      properties: {
        id: { type: "string" }
      },
      required: ["id"]
    }
  }]
}));

// Connect standard input/output transport
const transport = new StdioServerTransport();
await server.connect(transport);`}</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Learning Paths & Resources View (Tab 2) -->
  <div id="view-learning" class="tab-view container" role="tabpanel" aria-labelledby="tab-learning" tabindex="0">
    <section class="resources-explorer-section">
      <div class="resources-filter-bar glass-panel">
        <!-- Free vs Paid filter -->
        <div class="filter-group">
          <span class="filter-label">Cost:</span>
          <div class="cost-toggles">
            <button class="cost-btn active" data-cost="all">All</button>
            <button class="cost-btn" data-cost="free">Free</button>
            <button class="cost-btn" data-cost="paid">Paid</button>
          </div>
        </div>

        <!-- Topic Category filter -->
        <div class="filter-group">
          <span class="filter-label">Topic:</span>
          <select id="resource-category" class="sort-select">
            <option value="all">All Topics</option>
            <option value="llm-fundamentals">LLM Fundamentals</option>
            <option value="agent-orchestration">Agent Orchestration</option>
            <option value="custom-mcp">Custom MCP Dev</option>
          </select>
        </div>

        <!-- Experience Level filter -->
        <div class="filter-group">
          <span class="filter-label">Level:</span>
          <select id="resource-level" class="sort-select">
            <option value="all">All Levels</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>
        </div>

        <!-- Sort Selectors -->
        <div class="filter-group">
          <span class="filter-label">Sort By:</span>
          <select id="resource-sort" class="sort-select">
            <option value="rating">Highest Reviews ⭐️</option>
            <option value="price-asc">Price: Low to High 📈</option>
            <option value="price-desc">Price: High to Low 📉</option>
          </select>
        </div>
      </div>

      <!-- Resources Grid (Pre-rendered for SEO) -->
      <div class="resources-grid" id="resources-grid">
        {learningResources.map(res => {
          const priceText = res.cost === "free" ? "Free" : `$${res.price.toFixed(2)}`;
          const priceClass = res.cost === "free" ? "free" : "paid";
          const categoryTitle = categoryMap[res.courseCategory] || res.courseCategory;
          
          return (
            <div class="resource-card glass-panel" data-resource-id={res.id}>
              <div class="card-top">
                <div class="card-title-wrap">
                  <div>
                    <h3 class="card-name">{res.title}</h3>
                    <div style="display:flex; gap:6px; margin-top:6px; flex-wrap:wrap;">
                      <span class="resource-badge">{res.type}</span>
                      <span class="level-badge">{res.level}</span>
                      <span class="category-badge">{categoryTitle}</span>
                    </div>
                  </div>
                </div>
                {res.badge && <span class="badge" style="margin-bottom:0; font-size:0.6rem; padding:4px 10px;">{res.badge}</span>}
              </div>
              <p class="card-desc">{res.description}</p>
              
              <div class="card-footer" style="border:none; padding-top:0;">
                <span class="card-author">By {res.author}</span>
                <div class="price-container">
                  <span class={`price-tag ${priceClass}`}>{priceText}</span>
                </div>
              </div>
              
              <div class="card-footer" style="padding-top:10px;">
                <div class="rating-stars" aria-label={`Rating: ${res.rating.toFixed(1)} out of 5 stars based on ${res.reviewCount} reviews`}>
                  <span class="rating-value" aria-hidden="true">{res.rating.toFixed(1)}</span>
                  <span aria-hidden="true">
                    {"★".repeat(Math.floor(res.rating)) + "☆".repeat(5 - Math.floor(res.rating))}
                  </span>
                  <span class="rating-count" aria-hidden="true">({res.reviewCount})</span>
                </div>
                <div style="display: flex; gap: 8px;">
                  <a href={`/learning/${res.id}`} class="btn btn-secondary btn-sm">Info</a>
                  <a href={res.url} target="_blank" rel="noopener sponsored" class="btn btn-primary btn-sm">
                    Visit Resource ↗
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </div>

  <!-- Config Validator View (Tab 3) -->
  <div id="view-validator" class="tab-view container" role="tabpanel" aria-labelledby="tab-validator" tabindex="0">
    <section class="resources-explorer-section" style="padding-top:20px;">
      <div class="generator-layout">
        <!-- Editor Input Panel (Left) -->
        <div class="generator-controls glass-panel" style="padding:30px; display:flex; flex-direction:column;">
          <div class="output-header" style="margin-bottom:16px;">
            <h3 class="panel-title" id="validator-title" style="margin-bottom:0; border:none; padding:0;">Paste your mcp_config.json</h3>
            <button class="btn btn-secondary btn-sm" id="btn-load-sample" style="font-size:0.75rem;">Load Sample</button>
          </div>
          <label for="validator-textarea" class="sr-only">Paste your mcp_config.json configuration</label>
          <textarea id="validator-textarea" aria-labelledby="validator-title" placeholder={`{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your_token"
      }
    }
  }
}`} style="flex-grow:1; width:100%; min-height:400px; background:#04060a; border:1px solid var(--card-border); border-radius:8px; padding:16px; color:#c3e88d; font-family:monospace; font-size:0.85rem; outline:none; resize:vertical; line-height:1.5;"></textarea>
        </div>

        <!-- Validation Report Panel (Right) -->
        <div class="generator-output glass-panel" style="padding:30px; display:flex; flex-direction:column;">
          <h3 class="panel-title">Validation Report</h3>
          <div id="validator-status-container">
            <!-- Will render dynamic validation state card -->
            <div class="validation-alert info" style="display:flex; gap:16px; background:rgba(79, 172, 254, 0.08); border:1px solid rgba(79, 172, 254, 0.2); border-radius:8px; padding:16px;">
              <span style="font-size:1.5rem; line-height:1.2;">💡</span>
              <div>
                <strong style="color:var(--accent-blue); display:block; font-size:0.95rem;">Waiting for input...</strong>
                <span style="font-size:0.85rem; color:var(--text-secondary); display:block; margin-top:4px;">Paste your configuration JSON in the editor on the left to begin audit.</span>
              </div>
            </div>
          </div>
          
          <div style="margin-top:20px; flex-grow:1; display:flex; flex-direction:column; gap:12px;" id="validator-rules-logs">
            <!-- Audit Checklist items -->
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Client-side script handling search, config generator, validation and interactive tabs -->
  <script is:inline>
    // State-managed data loaded asynchronously
    let mcpRegistry = [];
    let learningResources = [];

    // Map category IDs to user-friendly titles
    const categoryMap = {
      "llm-fundamentals": "LLM Fundamentals",
      "agent-orchestration": "Agent Orchestration",
      "custom-mcp": "Custom MCP Dev"
    };

    // DOM Elements
    const serverGrid = document.getElementById("server-grid");
    const resourcesGrid = document.getElementById("resources-grid");
    const searchInput = document.getElementById("search-input");
    const categoryFilters = document.getElementById("category-filters");
    const controlsList = document.getElementById("controls-list");
    const jsonPreview = document.getElementById("json-preview");
    const copyConfigBtn = document.getElementById("copy-config-btn");
    const toast = document.getElementById("toast-notification");

    // Tab toggles
    const tabViews = document.querySelectorAll(".tab-view");
    const pageTabs = document.querySelectorAll(".page-tab");
    const tabLinks = document.querySelectorAll(".tab-nav-link");

    // Resource filters
    const resourceSort = document.getElementById("resource-sort");
    const resourceCategorySelect = document.getElementById("resource-category");
    const resourceLevelSelect = document.getElementById("resource-level");
    const costBtns = document.querySelectorAll(".cost-btn");

    // Validator Elements
    const validatorTextarea = document.getElementById("validator-textarea");
    const validatorStatusContainer = document.getElementById("validator-status-container");
    const validatorRulesLogs = document.getElementById("validator-rules-logs");
    const btnLoadSample = document.getElementById("btn-load-sample");

    // Application State
    let activeTab = "servers";
    let currentCategory = "all";
    let costFilter = "all";
    let resourceCategoryFilter = "all";
    let resourceLevelFilter = "all";
    let sortBy = "rating";
    let searchQuery = "";
    let selectedServers = {
      kite: true
    };
    let serverParamValues = {};

    // New state for layout and pagination
    let currentPage = 1;
    const pageSize = 12;
    let activeLayout = "grid"; // "grid" or "list"

    // Initialize Website
    async function init() {
      try {
        const response = await fetch('/data.json?v=' + new Date().getTime());
        if (!response.ok) throw new Error("HTTP error " + response.status);
        const data = await response.json();
        
        mcpRegistry = data.mcpRegistry;
        learningResources = data.learningResources;
        
        // Render and bind
        renderServers();
        renderResources();
        setupEventListeners();
        renderConfigGenerator();
        updateConfigJSON();

        // Check URL parameters for deep links from detail pages
        const urlParams = new URLSearchParams(window.location.search);
        const selectServerId = urlParams.get('select');
        if (selectServerId && mcpRegistry.some(s => s.id === selectServerId)) {
          selectedServers = { [selectServerId]: true };
          renderConfigGenerator();
          updateConfigJSON();
          
          // Switch to config builder view if select query is active
          const genSection = document.getElementById("config-generator");
          if (genSection) {
            genSection.scrollIntoView({ behavior: 'smooth' });
          }
        }
      } catch (err) {
        console.error("Failed to load registry data", err);
      }
    }

    // Lightweight JSON syntax highlighter
    function highlightJSON(jsonString) {
      if (!jsonString) return "";
      let html = jsonString
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
      
      const regex = /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g;
      
      return html.replace(regex, function (match) {
        let cls = 'json-number';
        if (/^"/.test(match)) {
          if (/:$/.test(match)) {
            cls = 'json-key';
          } else {
            cls = 'json-string';
          }
        } else if (/true|false/.test(match)) {
          cls = 'json-boolean';
        } else if (/null/.test(match)) {
          cls = 'json-null';
        }
        return '<span class="' + cls + '">' + match + '</span>';
      });
    }

    // Direct card-specific config copies
    window.copyServerConfig = function(serverId) {
      const server = mcpRegistry.find(s => s.id === serverId);
      if (!server) return;
      
      const defaults = {};
      if (serverId === "github") {
        defaults.GITHUB_PERSONAL_ACCESS_TOKEN = "YOUR_GITHUB_TOKEN";
      } else if (serverId === "postgres") {
        defaults.connectionString = "postgresql://localhost:5432/mydb";
      } else if (serverId === "slack") {
        defaults.SLACK_BOT_TOKEN = "YOUR_SLACK_BOT_TOKEN";
      } else if (serverId === "brave-search") {
        defaults.BRAVE_API_KEY = "YOUR_BRAVE_API_KEY";
      } else if (serverId === "filesystem") {
        defaults.allowedDirectories = "/path/to/folder";
      }
      
      const singleConfig = {
        mcpServers: {
          [serverId]: server.id === "github" ? {
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-github"],
            env: { GITHUB_PERSONAL_ACCESS_TOKEN: defaults.GITHUB_PERSONAL_ACCESS_TOKEN }
          } : server.id === "postgres" ? {
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-postgres", defaults.connectionString]
          } : server.id === "slack" ? {
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-slack"],
            env: { SLACK_BOT_TOKEN: defaults.SLACK_BOT_TOKEN }
          } : server.id === "brave-search" ? {
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-brave-search"],
            env: { BRAVE_API_KEY: defaults.BRAVE_API_KEY }
          } : server.id === "filesystem" ? {
            command: "npx",
            args: ["-y", "@modelcontextprotocol/server-filesystem", defaults.allowedDirectories]
          } : server.id === "kite" ? {
            command: "npx",
            args: ["-y", "mcp-remote", "https://mcp.kite.trade/mcp"]
          } : {
            command: "npx",
            args: ["-y", `@modelcontextprotocol/server-${serverId}`]
          }
        }
      };
      
      const text = JSON.stringify(singleConfig, null, 2);
      navigator.clipboard.writeText(text).then(() => {
        showToast(`${server.name} config block copied!`);
      }).catch(() => {
        alert("Copy failed.");
      });
    };

    // Render the grid cards dynamically
    function renderServers() {
      if (!serverGrid) return;
      serverGrid.innerHTML = "";
      
      const filtered = mcpRegistry.filter(server => {
        const matchesCategory = currentCategory === "all" || server.category === currentCategory;
        const matchesSearch = server.name.toLowerCase().includes(searchQuery.toLowerCase()) || 
                              server.description.toLowerCase().includes(searchQuery.toLowerCase());
        return matchesCategory && matchesSearch;
      });

      // Update screen reader results status
      const announcer = document.getElementById("search-results-announcer");
      if (announcer) {
        announcer.textContent = filtered.length === 0 ? "No servers found." : `${filtered.length} servers found.`;
      }

      // Calculate pagination
      const totalPages = Math.ceil(filtered.length / pageSize) || 1;
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;
      
      const startIdx = (currentPage - 1) * pageSize;
      const paginatedItems = filtered.slice(startIdx, startIdx + pageSize);

      if (paginatedItems.length === 0) {
        serverGrid.innerHTML = `
          <div class="no-results" style="grid-column: 1/-1; text-align: center; padding: 40px; color: var(--text-muted);">
            <p style="font-size: 1.2rem; margin-bottom: 8px;">No servers found</p>
            <p style="font-size: 0.9rem;">Try searching for another keyword or check the spelling.</p>
          </div>
        `;
        renderPagination(0, 1);
        return;
      }

      // Set layout class on grid
      if (activeLayout === "list") {
        serverGrid.classList.add("list-layout");
      } else {
