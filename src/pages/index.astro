          <p class="card-desc">${server.description}</p>
          
          <div class="card-actions">
            <div class="card-install">
              <span class="install-cmd" id="cmd-${server.id}">${server.command}</span>
              <button class="btn-copy" onclick="copyText('cmd-${server.id}', 'Command copied!')" title="Copy install command" aria-label="Copy install command">
                <span aria-hidden="true">📋</span>
              </button>
            </div>
            <button class="btn-card-action" onclick="copyServerConfig('${server.id}')" title="Copy default mcp_config.json block">
              <span role="img" aria-hidden="true">⚙️</span> Copy JSON
            </button>
          </div>
          
          <div class="card-footer">
            <span class="card-author">By ${server.author} &bull; <a href="/servers/${server.id}" class="details-link" style="color: var(--accent-blue); text-decoration: none; font-weight: 500;">Details &rarr;</a></span>
            <span class="card-stars"><span role="img" aria-label="stars">⭐️</span> ${server.stars}</span>
