---
import Layout from '../../layouts/Layout.astro';
import data from '../../../data.json';

export async function getStaticPaths() {
  return data.mcpRegistry.map(server => ({
    params: { id: server.id },
    props: { server }
  }));
}

const { server } = Astro.props;
const serverId = server.id;

// Generate customized configuration block
let configObj = {};
if (serverId === "github") {
  configObj = {
    command: "npx",
    args: ["-y", "@modelcontextprotocol/server-github"],
    env: { GITHUB_PERSONAL_ACCESS_TOKEN: "YOUR_GITHUB_TOKEN" }
  };
} else if (serverId === "postgres") {
  configObj = {
    command: "npx",
    args: ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost:5432/mydb"]
  };
} else if (serverId === "slack") {
  configObj = {
    command: "npx",
    args: ["-y", "@modelcontextprotocol/server-slack"],
    env: { SLACK_BOT_TOKEN: "YOUR_SLACK_BOT_TOKEN" }
  };
} else if (serverId === "brave-search") {
  configObj = {
    command: "npx",
    args: ["-y", "@modelcontextprotocol/server-brave-search"],
    env: { BRAVE_API_KEY: "YOUR_BRAVE_API_KEY" }
  };
} else if (serverId === "filesystem") {
  configObj = {
    command: "npx",
    args: ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/folder"]
  };
} else if (serverId === "kite") {
  configObj = {
    command: "npx",
    args: ["-y", "mcp-remote", "https://mcp.kite.trade/mcp"]
  };
} else {
  configObj = {
    command: "npx",
    args: ["-y", `@modelcontextprotocol/server-${serverId}`]
  };
}

const finalConfig = {
  mcpServers: {
    [serverId]: configObj
  }
};

const configJson = JSON.stringify(finalConfig, null, 2);

// JSON-LD Structured Data Schema.org
const schemaJson = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": `${server.name} MCP Server`,
  "description": server.description,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Cross-platform",
  "downloadUrl": "https://github.com/modelcontextprotocol/servers",
  "author": {
    "@type": "Organization",
    "name": server.author
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout
  title={`${server.name} MCP Server | Run Command & mcp_config.json | MCP Hub`}
  description={`Learn how to configure and run the ${server.name} Model Context Protocol (MCP) server. Run command: ${server.command}. Get full integration configuration details.`}
  canonicalUrl={`https://mcptools.dev/servers/${server.id}`}
  ogType="article"
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />

  <article class="container" style="padding-top: 40px; padding-bottom: 80px; min-height: 80vh;">
    <!-- Breadcrumbs -->
    <div class="breadcrumbs" style="margin-bottom: 24px; font-size: 0.85rem; color: var(--text-secondary); display: flex; gap: 8px;">
      <a href="/" style="color: var(--accent-blue); text-decoration: none;">Home</a>
      <span aria-hidden="true">&gt;</span>
      <a href="/#servers-explorer" style="color: var(--accent-blue); text-decoration: none;">Servers</a>
      <span aria-hidden="true">&gt;</span>
      <span style="color: var(--text-muted);">{server.name}</span>
    </div>

    <!-- Details Layout -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 32px; align-items: start;" class="details-grid">
      <!-- Main Content (Left) -->
      <div style="display: flex; flex-direction: column; gap: 32px;">
        <div class="glass-panel" style="padding: 40px; position: relative;">
          <!-- Server Header -->
          <div style="display: flex; gap: 24px; align-items: center; margin-bottom: 24px;">
            <div style="font-size: 4rem; width: 90px; height: 90px; display: flex; align-items: center; justify-content: center; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--card-border); border-radius: 16px;" aria-hidden="true">
              {server.icon}
            </div>
            <div>
              <h1 style="font-size: 2.2rem; font-family: 'Space Grotesk', sans-serif; font-weight: 700; color: #fff; margin: 0 0 8px 0;">
                {server.name} <span style="font-size: 1.2rem; color: var(--text-secondary); font-weight: 400;">MCP Server</span>
              </h1>
              <div style="display: flex; gap: 12px; align-items: center;">
                <span class="card-badge" style="margin-bottom: 0;">{server.category}</span>
                <span style="font-size: 0.85rem; color: var(--text-muted);">By {server.author}</span>
              </div>
            </div>
          </div>

          <hr style="border: none; border-top: 1px solid var(--card-border); margin: 24px 0;" />

          <!-- Description -->
          <h2 style="font-size: 1.25rem; color: var(--text-secondary); font-family: 'Space Grotesk', sans-serif; margin-bottom: 12px;">Description</h2>
          <p style="font-size: 1.05rem; line-height: 1.6; color: var(--text-muted); margin-bottom: 30px;">
            {server.description}
          </p>

          <!-- Run Command -->
          <h2 style="font-size: 1.25rem; color: var(--text-secondary); font-family: 'Space Grotesk', sans-serif; margin-bottom: 12px;">Install & Run Command</h2>
          <div class="card-install" style="margin-bottom: 16px; background: #04060a; padding: 16px; border-radius: 8px; border: 1px solid var(--card-border); max-width: 100%;">
            <span class="install-cmd" id="install-cmd" style="font-family: monospace; font-size: 0.9rem; color: #c3e88d; word-break: break-all;">{server.command}</span>
            <button class="btn-copy" onclick="copyText('install-cmd', 'Command copied!')" title="Copy command" aria-label="Copy install command" style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 1.1rem; padding: 4px;">
              <span aria-hidden="true">📋</span>
            </button>
          </div>
          <span style="font-size: 0.8rem; color: var(--text-muted); display: block;">
            Use this command in your Model Context Protocol client environment (e.g., Claude Desktop config or other orchestration transport setups).
          </span>
        </div>

        <!-- Configuration preview -->
        <div class="glass-panel" style="padding: 40px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <h2 style="font-size: 1.25rem; color: var(--text-secondary); font-family: 'Space Grotesk', sans-serif; margin: 0;">mcp_config.json Snippet</h2>
            <button class="btn btn-secondary btn-sm" id="btn-copy-snippet" style="font-size: 0.8rem;">
              <span aria-hidden="true">📋</span> Copy Snippet
            </button>
          </div>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 16px;">
            Add this configuration block inside your local client <code>mcpServers</code> section:
          </p>
          <div class="code-container" style="background: #04060a; border: 1px solid var(--card-border); border-radius: 8px; padding: 20px; overflow-x: auto;">
            <pre><code id="json-snippet" style="font-family: monospace; font-size: 0.85rem; color: #82aaff; line-height: 1.5;"><span style="color:#c792ea;">"mcpServers":</span><br />{configJson}</code></pre>
          </div>
        </div>
      </div>

      <!-- Sidebar Metadata (Right) -->
      <div class="glass-panel" style="padding: 30px; display: flex; flex-direction: column; gap: 24px;">
        <h3 style="font-size: 1.15rem; font-family: 'Space Grotesk', sans-serif; margin: 0; color: #fff;">Server Details</h3>
        
        <div>
          <span style="font-size: 0.8rem; color: var(--text-muted); display: block; text-transform: uppercase; margin-bottom: 4px;">Stars & Popularity</span>
          <strong style="font-size: 1.1rem; color: #fff;"><span role="img" aria-label="stars">⭐️</span> {server.stars}</strong>
        </div>

        <div>
          <span style="font-size: 0.8rem; color: var(--text-muted); display: block; text-transform: uppercase; margin-bottom: 4px;">Author</span>
          <strong style="font-size: 1.1rem; color: #fff;">{server.author}</strong>
        </div>

        <div>
          <span style="font-size: 0.8rem; color: var(--text-muted); display: block; text-transform: uppercase; margin-bottom: 4px;">Category</span>
          <strong style="font-size: 1.1rem; color: #fff; text-transform: capitalize;">{server.category}</strong>
        </div>

        <div>
          <span style="font-size: 0.8rem; color: var(--text-muted); display: block; text-transform: uppercase; margin-bottom: 4px;">Status</span>
          <strong style="font-size: 1.1rem; color: var(--accent-blue);"><span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:var(--accent-blue); margin-right:6px;" aria-hidden="true"></span>Active / Stable</strong>
        </div>

        <hr style="border: none; border-top: 1px solid var(--card-border); margin: 8px 0;" />

        <!-- Actions -->
        <a href={`/?select=${server.id}#config-generator`} class="btn btn-primary text-center" style="display: block; text-decoration: none; font-size: 0.95rem; font-weight: 600;">
          ⚡ Try in Config Builder
        </a>

        <a href="/" class="btn btn-secondary text-center" style="display: block; text-decoration: none; font-size: 0.95rem;">
          &larr; Back to Registry
        </a>
      </div>
    </div>
  </article>

  <script is:inline define:vars={{ configJson }}>
    // Card copy utilities
    window.copyText = function(elementId, successMessage) {
      const element = document.getElementById(elementId);
      if (!element) return;
      const text = element.textContent;
      navigator.clipboard.writeText(text).then(() => {
        const toast = document.getElementById("toast-notification");
        if (toast) {
          toast.textContent = successMessage;
          toast.classList.add("active");
          setTimeout(() => toast.classList.remove("active"), 2500);
        }
      }).catch(() => {
        alert("Failed to copy command.");
      });
    };

    // Copy snippet action
    document.addEventListener("DOMContentLoaded", () => {
      const btnCopy = document.getElementById("btn-copy-snippet");
      if (btnCopy) {
        btnCopy.addEventListener("click", () => {
          navigator.clipboard.writeText(configJson).then(() => {
            const toast = document.getElementById("toast-notification");
            if (toast) {
              toast.textContent = "Configuration snippet copied!";
              toast.classList.add("active");
              setTimeout(() => toast.classList.remove("active"), 2500);
            }
          });
        });
      }
    });
  </script>
</Layout>

<style>
  @media (max-width: 768px) {
    .details-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
